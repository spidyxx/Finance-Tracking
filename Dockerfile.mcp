# MCP server image (LAN-only). Runs the Streamable HTTP MCP endpoint via tsx,
# reusing the same service layer as the web app. Separate from the web image
# because it needs the TypeScript sources + tsx at runtime.
FROM node:22-slim
RUN apt-get update -y && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund

COPY prisma ./prisma
RUN npx prisma generate

COPY tsconfig.json ./
COPY src ./src
COPY mcp ./mcp

ENV MCP_PORT=3001
EXPOSE 3001
CMD ["npx", "tsx", "mcp/server.ts"]
