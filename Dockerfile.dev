# Dev image used by scripts/dev.sh. Same base as production plus OpenSSL, which
# Prisma's query engine needs at runtime — without it Prisma misdetects the
# OpenSSL version and looks for the wrong query engine binary.
FROM node:22-slim
RUN apt-get update -y \
    && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
