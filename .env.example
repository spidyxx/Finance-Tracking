# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
#
# NO QUOTES around values. deploy uses `docker run --env-file`, which does NOT
# strip quotes — a quoted value keeps the literal " and breaks (e.g. Prisma
# rejects DATABASE_URL "postgresql://..."). Values have no spaces, so bare is fine.

# --- Database -------------------------------------------------------------
# Dedicated 'finance' database on the existing PostgreSQL instance.
DATABASE_URL=postgresql://finance:CHANGE_ME@192.168.178.70:5432/finance?schema=public

# --- Auth (single shared password) ---------------------------------------
# Cookie signing secret, >= 32 chars.  Generate: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_random_at_least_32_chars
# Login password as a base64-encoded bcrypt hash.  Generate: npm run hash-password
APP_PASSWORD_HASH=CHANGE_ME_base64_bcrypt_hash

# --- MCP server (LAN-only) ------------------------------------------------
# Bearer token required by MCP clients.  Generate: openssl rand -hex 32
MCP_API_KEY=CHANGE_ME_random_token

# --- Ports ----------------------------------------------------------------
PORT=3000
MCP_PORT=3001
